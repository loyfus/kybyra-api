# Server
NODE_ENV=development
PORT=3000

# Database (PostgreSQL + PostGIS)
DATABASE_URL="postgresql://kybyra:kybyra@localhost:5432/kybyra?schema=public"

# JWT (use long random strings in production)
JWT_ACCESS_SECRET="change-me-access-please-use-strong-secret"
JWT_REFRESH_SECRET="change-me-refresh-please-use-strong-secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# CORS allowed origins (comma-separated; empty = allow all in dev)
CORS_ORIGINS="http://localhost:8081,http://localhost:19006,http://localhost:19000"

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Logging
LOG_LEVEL=debug

# Sentry (optional - leave empty to disable)
SENTRY_DSN=""

# External APIs
OCM_API_KEY=""
OCM_BASE_URL="https://api.openchargemap.io/v3"
NHTSA_BASE_URL="https://vpic.nhtsa.dot.gov/api/vehicles"
