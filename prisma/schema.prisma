// Prisma schema for Kybyra API.
// PostGIS extension will be enabled in Sprint 4 (Stations). For Sprint 1
// (Auth) we don't need geographical types yet, so the extension is omitted
// to keep `prisma migrate dev` from requiring extra DB privileges/installs.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Sprints 2+ will add Car, UserCar, Favorite, StationCache, etc.

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  avatarUrl    String?
  locale       String    @default("pt-BR")
  theme        Theme     @default(SYSTEM)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  refreshTokens    RefreshToken[]
  deletionRequests AccountDeletionRequest[]
  userCars         UserCar[]
  favorites        Favorite[]

  @@map("users")
}

model RefreshToken {
  id                String    @id // jti claim of the JWT
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash         String    @unique // sha256 of the issued JWT
  userAgent         String?
  ipAddress         String?
  createdAt         DateTime  @default(now())
  expiresAt         DateTime
  revokedAt         DateTime?
  replacedByTokenId String?

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model AccountDeletionRequest {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  requestedAt  DateTime  @default(now())
  scheduledFor DateTime
  cancelledAt  DateTime?
  completedAt  DateTime?

  @@index([userId])
  @@index([scheduledFor])
  @@map("account_deletion_requests")
}

enum Theme {
  SYSTEM
  LIGHT
  DARK
}

model Car {
  id     String  @id @default(cuid())
  slug   String  @unique
  brand  String
  model  String
  variant String?
  year   Int

  // Classification
  bodyStyle  String? // sedan, suv, hatchback, pickup, coupe, wagon
  segment    String? // compact, midsize, fullsize, premium, luxury
  drivetrain String? // FWD, RWD, AWD
  isHybrid   Boolean @default(false)
  isPhev     Boolean @default(false)

  // Power & performance
  motorPowerKw   Int?
  motorTorqueNm  Int?
  topSpeedKmh    Int?
  zeroToHundredS Float?

  // Battery
  batteryKwh       Float?
  usableBatteryKwh Float?
  rangeKmWltp      Int?
  rangeKmEpa       Int?
  efficiencyWhKm   Int?

  // Charging
  acChargerKw      Float?
  dcChargerKw      Float?
  chargingPortType String? // CCS2, NACS, Type2, ChaDeMo, GB/T

  // Dimensions
  lengthMm        Int?
  widthMm         Int?
  heightMm        Int?
  weightKg        Int?
  cargoLiters     Int?
  seatingCapacity Int?

  // Pricing (optional, dev-time)
  msrpUsd  Int?
  priceBrl Int?

  // Meta
  imageUrl           String? // local path served by /uploads/cars/<slug>.jpg
  imageAttribution   String? // e.g. "Photo by John Doe / Wikipedia, CC-BY-SA 4.0"
  imageSourceUrl     String? // canonical source (Wikipedia/Commons page)
  wikidataId         String? // e.g. Q2105 for Tesla Model 3 (used by importer)
  description        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userCars  UserCar[]
  favorites Favorite[]

  @@index([brand])
  @@index([year])
  @@index([rangeKmWltp])
  @@index([isHybrid, isPhev])
  @@map("cars")
}

model UserCar {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  carId       String
  car         Car       @relation(fields: [carId], references: [id], onDelete: Cascade)
  nickname    String?
  purchasedAt DateTime?
  odometerKm  Int?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, carId])
  @@index([userId])
  @@map("user_cars")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  carId     String
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, carId])
  @@index([userId])
  @@map("favorites")
}
